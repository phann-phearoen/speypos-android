<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:background="@color/shell_background">

  <WebView
    android:id="@+id/webView"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:overScrollMode="never" />

  <LinearLayout
    android:id="@+id/errorContainer"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@color/shell_background"
    android:visibility="gone">

    <TextView
      android:id="@+id/errorTitle"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:text="SpeyPOS could not start"
      android:textColor="@color/shell_foreground"
      android:textSize="22sp"
      android:textStyle="bold" />

    <TextView
      android:id="@+id/errorMessage"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_marginTop="12dp"
      android:gravity="center"
      android:text="The packaged frontend did not load."
      android:textColor="@color/shell_muted_foreground"
      android:textSize="16sp" />

    <com.google.android.material.button.MaterialButton
      android:id="@+id/retryButton"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_marginTop="20dp"
      android:text="Retry"
      app:cornerRadius="14dp" />
  </LinearLayout>

</FrameLayout>