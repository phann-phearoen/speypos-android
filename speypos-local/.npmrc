# On Termux/Android, Node 24 ships a common.gypi that requires android_ndk_path
# to be defined (even for native/non-NDK Termux builds). Setting it to the
# Termux usr prefix satisfies the gyp parser and lets better-sqlite3 compile
# using Termux's own clang — no actual Android NDK is needed.
# This value is ignored on macOS/Linux where android_ndk_path is never referenced.
android_ndk_path=/data/data/com.termux/files/usr
