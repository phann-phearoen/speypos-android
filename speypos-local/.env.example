# SpeyPOS Local — Environment Variables
# Copy this file to .env and fill in values for your deployment.

# ─── Required ────────────────────────────────────────────────────────────────

# TCP port the backend HTTP server will listen on.
PORT=8080

# Absolute or relative path to the SQLite database file.
# The directory will be created if it does not exist.
DB_PATH=./data/pos.db

# ─── Runtime Profile ─────────────────────────────────────────────────────────

# Deployment profile. Controls default behaviour for printer mode etc.
# Options: default | android-termux | development
RUNTIME_PROFILE=android-termux

# ─── Printer ─────────────────────────────────────────────────────────────────

# Force all print output to the console instead of a LAN printer.
# true  → safe console-only mode (default when RUNTIME_PROFILE=android-termux)
# false → use printer.lan settings (set via PUT /api/settings/printer.lan)
FORCE_CONSOLE_PRINTER=true

# ─── Networking ──────────────────────────────────────────────────────────────

# Origin allowed by CORS for the PWA frontend.
# Must match the URL the browser uses to load the PWA.
CORS_ORIGIN=http://localhost:8000

# ─── Cloud Sync ──────────────────────────────────────────────────────────────

# Base URL for the cloud sync API. Leave at default unless self-hosting.
# api_key and store_id are managed via PUT /api/settings/cloud.sync
CLOUD_BASE_URL=https://speypos-cloud.ryong.net

# ─── Integrations (Optional) ─────────────────────────────────────────────────

# Telegram bot token for order/shift notifications.
# Omit or leave blank to disable Telegram integration entirely.
# chat_id per intent is configured via PUT /api/settings/telegram.intents — NOT here.
TELEGRAM_BOT_TOKEN=

# ─── Observability (Optional) ────────────────────────────────────────────────

# Node environment. Controls logger verbosity.
# production  → info level and above
# (anything else) → debug level
NODE_ENV=production

# ─── Cloud Sync Tuning (Optional) ────────────────────────────────────────────

# Number of records per mini-batch during cloud sync upload.
# Valid range: 1..200. Default: 20.
SYNC_MINI_BATCH_SIZE=20

# Timeout in milliseconds for outbound cloud sync HTTP requests.
# Prevents indefinite hangs on unstable WiFi. Default: 15000 (15 s).
# CLOUD_FETCH_TIMEOUT_MS=15000

# Timeout in milliseconds for outbound Telegram notification requests.
# Default: 8000 (8 s).
# TELEGRAM_FETCH_TIMEOUT_MS=8000
